<h1>Movimientos</h1>

<!-- Filtros -->
<%= form_tag movements_path, method: :get, class: 'row g-3 mb-3' do %>
  <div class="col-auto">
    <%= select_tag :movement_type, options_for_select([['Todos', ''], ['Ingreso', 'income'], ['Gasto', 'expense'], ['Transferencia', 'transfer']], params[:movement_type]), class: 'form-select' %>
  </div>
  <div class="col-auto">
    <%= date_field_tag :date_from, params[:date_from], class: 'form-control', placeholder: 'Desde' %>
  </div>
  <div class="col-auto">
    <%= date_field_tag :date_to, params[:date_to], class: 'form-control', placeholder: 'Hasta' %>
  </div>
  <div class="col-auto">
    <%= submit_tag 'Filtrar', class: 'btn btn-secondary' %>
    <%= link_to 'Limpiar', movements_path, class: 'btn btn-outline-secondary' %>
  </div>
<% end %>

<%= link_to 'Nuevo Movimiento', new_movement_path, class: 'btn btn-primary' %>

<table class="table">
  <thead>
    <tr>
      <th>Fecha</th>
      <th>Descripción</th>
      <th>Tipo</th>
      <th>Monto</th>
      <th>Origen</th>
      <th>Destino</th>
      <th colspan="3">Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @movements.each do |movement| %>
      <tr>
        <td><%= movement.date %></td>
        <td><%= link_to movement.description, movement_path(movement) %></td>
        <td><%= movement.movement_type.humanize %></td>
        <td><%= number_to_currency(movement.amount) %></td>
        <td><%= movement.source_account&.name %></td>
        <td><%= movement.destination_account&.name %></td>
        <td><%= link_to 'Ver', movement_path(movement), class: 'btn btn-info btn-sm' %></td>
        <td><%= link_to 'Editar', edit_movement_path(movement), class: 'btn btn-warning btn-sm' %></td>
        <td><%= link_to 'Eliminar', movement_path(movement), data: { turbo_method: :delete, turbo_confirm: '¿Estás seguro?' }, class: 'btn btn-danger btn-sm' %></td>
      </tr>
    <% end %>
  </tbody>
</table>